# ===================================
# AI Code Review - Environment Variables
# ===================================
# Copy this file to .env.local and fill in your values

# ===================================
# Required
# ===================================

# NextAuth secret (generate with: openssl rand -base64 32)
AUTH_SECRET=your-secret-key-here

# ===================================
# OAuth Providers (Optional)
# ===================================

# Google Workspace OAuth (Restricted to @tvtgroup.io)
# Create app at: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth
# Create app at: https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# GitLab.com OAuth
# Create app at: https://gitlab.com/-/profile/applications
AUTH_GITLAB_ID=
AUTH_GITLAB_SECRET=

# GitLab Self-Hosted OAuth (Optional)
AUTH_GITLAB_SELF_HOSTED_ID=
AUTH_GITLAB_SELF_HOSTED_SECRET=
AUTH_GITLAB_SELF_HOSTED_ISSUER=https://gitlab.yourcompany.com

# ===================================
# AI Providers (Optional)
# ===================================

# Google Gemini API Key (Recommended - has free tier)
# Get from: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Anthropic Claude API Key
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ===================================
# Mobile API Checker (Optional)
# ===================================

# GitLab project ID for the backend repo (used by Mobile API Impact Checker)
# GITLAB_BACKEND_PROJECT_ID=42
# GITLAB_BRANCH=tvt_qc

# ===================================
# Email OTP / 2FA (Required for email login)
# ===================================

# SMTP settings for sending OTP emails
# Using Gmail / Google Workspace SMTP:
#   1. Enable 2-Step Verification on your Google account
#   2. Generate an App Password: https://myaccount.google.com/apppasswords
#   3. Use that App Password as SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@tvtgroup.io
SMTP_PASS=your-gmail-app-password
EMAIL_FROM="AI Code Review <noreply@tvtgroup.io>"

# ===================================
# Production Only
# ===================================

# Full URL of your app (required for OAuth callbacks in production)
# AUTH_URL=https://your-domain.com
